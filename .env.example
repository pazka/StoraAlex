# Copy to .env and fill. NEVER commit .env. See SPEC §7/§8.

# --- Server ---
PORT=8080
NODE_ENV=production
# App is meant to run behind a TLS-terminating reverse proxy on the VPS.
# Number of trusted proxy hops (1 = a single reverse proxy), or an IP/CIDR.
# Do NOT use "true": it trusts a client-spoofable X-Forwarded-For and lets an
# attacker bypass per-IP login rate limiting. Defaults to 1 in production.
TRUST_PROXY=1

# --- Secrets (generate strong random values) ---
# Server-side pepper mixed into password hashing, in addition to argon2's per-hash salt.
APP_PEPPER=
# Key used to sign session cookies.
SESSION_KEY=

# --- First user ---
# By default the first run prompts you to create the first account in the app
# (no admin is seeded). These optional vars let `npm run seed` pre-create a user
# headlessly instead; leave blank to use the in-app first-run setup.
SEED_ADMIN_USER=
SEED_ADMIN_PASSWORD=

# --- Storage ---
# Volume holding the SQLite DB and media. Mounted in Docker.
DATA_DIR=/data
# Optional overrides (defaults derive from DATA_DIR):
# DB_PATH=/data/storalex.db
# MEDIA_DIR=/data/media

# --- Optional tuning ---
# HOST=0.0.0.0
# SESSION_TTL_DAYS=30
# MAX_UPLOAD_BYTES=15728640   # 15 MiB cap per uploaded photo

# --- Google Sheet mirror ---
# Service-account JSON (path or inline). Share the target Sheet with the service-account email.
GOOGLE_SERVICE_ACCOUNT_JSON=/run/secrets/google-sa.json
SHEET_ID=
# Push DB -> Sheet at most this often (ms), plus periodic reconcile.
SHEET_SYNC_DEBOUNCE_MS=10000
