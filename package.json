{
  "name": "storalex",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "concurrently -k -n server,client -c blue,magenta \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:client": "vite",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.server.json && node scripts/copy-migrations.mjs",
    "start": "node dist/server/index.js",
    "typecheck": "tsc -p tsconfig.server.json --noEmit && tsc -p tsconfig.client.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "seed": "tsx src/server/seed.ts"
  },
  "dependencies": {
    "@fastify/cookie": "11.0.2",
    "@fastify/helmet": "13.0.2",
    "@fastify/multipart": "10.0.0",
    "@fastify/rate-limit": "11.0.0",
    "@fastify/static": "9.1.3",
    "@fastify/type-provider-typebox": "6.1.0",
    "@node-rs/argon2": "2.0.2",
    "@sinclair/typebox": "0.34.49",
    "@tanstack/react-query": "5.101.1",
    "@zxing/browser": "0.2.0",
    "@zxing/library": "0.22.0",
    "fastify": "5.8.5",
    "pdf-lib": "1.17.1",
    "qrcode": "1.5.4",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router-dom": "7.18.0",
    "sharp": "0.35.2"
  },
  "devDependencies": {
    "@types/node": "24.13.2",
    "@types/qrcode": "1.5.6",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "concurrently": "10.0.3",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vite": "8.1.0",
    "vite-plugin-pwa": "1.3.0",
    "vitest": "4.1.9"
  }
}
